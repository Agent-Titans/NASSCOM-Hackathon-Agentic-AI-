# Copy to .env and fill in. Never commit .env

# Google Gemini (required for Classifier, Resolver, embeddings)
GOOGLE_API_KEY=

# Free tier: prefer gemini-2.5-flash (generate) + gemini-embedding-001 (embed)
# Run: python scripts/check_gemini_models.py after adding GOOGLE_API_KEY
GEMINI_MODEL_CLASSIFY=gemini-2.5-flash
GEMINI_MODEL_RESOLVE=gemini-2.5-flash
GEMINI_MODEL_EMBED=gemini-embedding-001
# Chroma vectors: gemini (LLD default, needs API) | local (offline MiniLM fallback)
RAG_EMBEDDING_BACKEND=gemini

# Persistence
SQLITE_DATABASE_URL=sqlite:///./data/app.db
CHROMA_PERSIST_DIR=./data/chroma

# App
APP_ENV=development
LOG_LEVEL=INFO
SESSION_SECRET=change-me-in-production

# Supervisor thresholds (optional overrides)
C_TOTAL_HAND1=0.75
C_TOTAL_HAND2=0.60
RAG_TOP_K=8
# Set false after running scripts/bootstrap_rag_environment.py (avoids legacy demo re-seed)
RAG_AUTO_SEED=false
# synthetic | legacy | both — synthetic uses data/synthetic/tickets_1000.json
RAG_CORPUS_MODE=synthetic

# Optional — outbound ticket email (NOT used for portal login)
# Set EMAIL_NOTIFICATIONS_ENABLED=true and Gmail app password to send.
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=
